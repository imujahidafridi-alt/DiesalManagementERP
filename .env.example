# Cloud Vault Backup Configuration (Cloudflare R2 Example)
CLOUD_VAULT_ENABLED=true
CLOUD_VAULT_PROVIDER=cloudflare_r2
CLOUD_VAULT_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
CLOUD_VAULT_BUCKET_NAME=your-bucket-name
CLOUD_VAULT_ACCESS_KEY_ID=your-access-key-id
CLOUD_VAULT_SECRET_ACCESS_KEY=your-secret-access-key
CLOUD_VAULT_REGION=auto
